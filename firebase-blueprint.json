{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User's profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Session": {
      "title": "Session",
      "description": "A bill splitting session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "storeName": { "type": "string" },
        "englishStoreName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array", "items": { "type": "object" } },
        "people": { "type": "array", "items": { "type": "object" } },
        "tax": { "type": "number" },
        "tip": { "type": "number" },
        "total": { "type": "number" },
        "imageUrl": { "type": "string" },
        "id": { "type": "string" },
        "driveFileId": { "type": "string" },
        "driveLink": { "type": "string" }
      },
      "required": ["userId", "storeName", "createdAt", "items", "people", "tax", "tip", "total"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Bill splitting sessions."
    }
  }
}
